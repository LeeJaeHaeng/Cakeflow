# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT
ADMIN_JWT_SECRET=change-me
ADMIN_EMAIL=admin@cakeflow.local
ADMIN_PASSWORD=change-me-admin-password

# SMS (알리고)
ALIGO_API_KEY=your-aligo-api-key
ALIGO_USER_ID=your-aligo-user-id
ALIGO_SENDER=0210001000
ALIGO_KAKAO_SENDER_KEY=your-alimtalk-sender-key
ALIGO_TPL_ORDER_RECEIVED=your-order-received-template-code
ALIGO_TPL_PAYMENT_PAID=your-payment-paid-template-code
ALIGO_TPL_QUOTE_NEEDED=your-quote-needed-template-code
ALIGO_TPL_CONFIRMED=your-confirmed-template-code
ALIGO_TPL_PRODUCING=your-producing-template-code
ALIGO_TPL_READY=your-ready-template-code
ALIGO_TPL_COMPLETED=your-completed-template-code
ALIGO_TPL_CANCELLED=your-cancelled-template-code
ALIGO_TPL_REVIEW_REQUEST=your-review-request-template-code
SMS_MOCK_MODE=false

# 임시 주문 편의 플래그: true면 고객 주문서 휴대폰 인증을 건너뜁니다.
NEXT_PUBLIC_PHONE_AUTH_DISABLED=false
